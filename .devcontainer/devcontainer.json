{
  "name": "esp-nmea-bridge Zephyr",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "ZEPHYR_SDK_VERSION": "1.0.1"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "workspaceFolder": "/workspaces/esp-nmea-bridge-workspace/esp-nmea-bridge",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/esp-nmea-bridge-workspace/esp-nmea-bridge,type=bind,consistency=cached",
  "mounts": [
    "source=esp-nmea-bridge-west-workspace,target=/workspaces/esp-nmea-bridge-workspace,type=volume"
  ],
  "containerEnv": {
    "ZEPHYR_TOOLCHAIN_VARIANT": "zephyr",
    "ZEPHYR_SDK_INSTALL_DIR": "/opt/zephyr-sdk-1.0.1"
  },
  "postCreateCommand": "bash .devcontainer/setup-workspace.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "cmake.configureOnOpen": false
      }
    }
  }
}
