{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "west: build esp32c6",
      "type": "shell",
      "command": "west build -p always --sysbuild -b esp32c6_dev_kit_n8/esp32c6/hpcore . -- -DEXTRA_CONF_FILE=local.conf",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "west: flash esp32c6",
      "type": "shell",
      "command": "west flash --esp-device /dev/waveshare/esp32c6-dev-kit-n8/jtag",
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "west: twister tests",
      "type": "shell",
      "command": "west twister -c -O build/twister -T tests/ --inline-logs",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "west: update workspace",
      "type": "shell",
      "command": "bash .devcontainer/update-workspace.sh",
      "problemMatcher": []
    }
  ]
}
