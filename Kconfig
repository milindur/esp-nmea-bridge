# ESP NMEA Bridge application configuration

mainmenu "ESP NMEA Bridge"

menu "ESP NMEA-0183 serial bridge"

config ESP_NMEA_BRIDGE_AP_ENABLE
	bool "Enable ESP32 SoftAP"
	default y

config ESP_NMEA_BRIDGE_STA_ENABLE
	bool "Enable Wi-Fi station mode"
	default y

config ESP_NMEA_BRIDGE_TCP_NMEA_SERVER_ENABLE
	bool "Enable TCP NMEA server"
	default y

config ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_ENABLE
	bool "Enable TCP NMEA client"
	default y
	depends on ESP_NMEA_BRIDGE_STA_ENABLE

config ESP_NMEA_BRIDGE_WEB_APP_ENABLE
	bool "Enable HTTP status web app"
	default y
	depends on NETWORKING
	depends on NET_TCP
	depends on NET_SOCKETS
	help
	  Serve a small HTTP web app and JSON status endpoint on port 80.
	  The browser polls /api/status to display bridge telemetry counters.

config ESP_NMEA_BRIDGE_OTA_UPDATE_ENABLE
	bool "Enable WebApp firmware OTA updates"
	default n
	depends on ESP_NMEA_BRIDGE_WEB_APP_ENABLE
	depends on FLASH
	depends on FLASH_MAP
	depends on STREAM_FLASH
	depends on IMG_MANAGER
	select REBOOT
	help
	  Enable firmware upload through the local WebApp. Uploaded images are
	  written to the MCUboot upload slot and booted once as a test image.
	  Leave this disabled unless the WebApp network is trusted.

config ESP_NMEA_BRIDGE_OTA_MAX_UPLOAD_BYTES
	int "Maximum OTA upload size in bytes"
	default 0
	depends on ESP_NMEA_BRIDGE_OTA_UPDATE_ENABLE
	help
	  Optional upload-size ceiling. A value of 0 uses the MCUboot upload slot
	  size reported by the flash map at runtime.

config ESP_NMEA_BRIDGE_OTA_UPLOAD_TRUSTED_NETWORK_ENABLE
	bool "Allow WebApp OTA uploads from the reachable HTTP network"
	default n
	depends on ESP_NMEA_BRIDGE_OTA_UPDATE_ENABLE
	help
	  Allow POST /api/ota/upload to accept firmware bytes from clients that can
	  reach the WebApp. Enable only on an isolated or otherwise trusted network;
	  this is a deliberate acknowledgement that the endpoint has no per-user
	  authentication.

config ESP_NMEA_BRIDGE_STATUS_LED_ENABLE
	bool "Enable status LED observer"
	default y
	select LED_STRIP
	help
	  Enable the optional status LED observer. When enabled, the observer
	  looks for a NeoPixel-compatible LED strip through the led-strip
	  devicetree alias and renders NMEA connection state. Missing or
	  non-ready LED hardware is non-fatal.

config ESP_NMEA_BRIDGE_AIS_SELF_MMSI_FILTER_ENABLE
	bool "Enable AIS self-MMSI filter"
	default n
	help
	  Drop AIS VDM NMEA frames whose decoded MMSI matches the configured
	  own MMSI. Unknown, malformed, checksum-missing, checksum-invalid,
	  non-VDM, and VDO frames remain pass-through.

config ESP_NMEA_BRIDGE_AIS_SELF_MMSI_FILTER_MMSI
	int "Own MMSI for AIS self-MMSI filter"
	default 0
	range 0 999999999
	depends on ESP_NMEA_BRIDGE_AIS_SELF_MMSI_FILTER_ENABLE
	help
	  Own MMSI to filter. A value of 0 leaves the filter effectively
	  inactive even when the feature is built in.

config ESP_NMEA_BRIDGE_MDNS_ENABLE
	bool "Enable mDNS hostname responder"
	default n
	select NET_HOSTNAME_ENABLE
	select MDNS_RESPONDER
	help
	  Enable Zephyr's mDNS responder so the device can answer
	  <hostname>.local queries. Set CONFIG_NET_HOSTNAME to choose the
	  hostname.

config ESP_NMEA_BRIDGE_DNS_SD_ENABLE
	bool "Advertise enabled services via DNS-SD"
	default n
	depends on ESP_NMEA_BRIDGE_MDNS_ENABLE
	depends on ESP_NMEA_BRIDGE_TCP_NMEA_SERVER_ENABLE || ESP_NMEA_BRIDGE_WEB_APP_ENABLE
	select DNS_SD
	select MDNS_RESPONDER_DNS_SD
	help
	  Advertise enabled network services via DNS Service Discovery. The TCP
	  NMEA-0183 server is advertised as _nmea-0183._tcp.local when enabled;
	  the built-in web app is advertised as _http._tcp.local when enabled.
	  Services are only advertised when the corresponding listener is built in.

config ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_HOST
	string "TCP NMEA server IPv4 address"
	default ""
	depends on ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_ENABLE
	help
	  IPv4 address of the upstream TCP NMEA server. Leave empty to use the
	  DHCP gateway learned on the STA interface, useful when the ESP connects
	  directly to a Raspberry Pi/OpenPlotter hotspot.

config ESP_NMEA_BRIDGE_AP_SSID
	string "SoftAP SSID"
	default "ESP-NMEA0183"

config ESP_NMEA_BRIDGE_AP_PSK
	string "SoftAP WPA2 PSK password"
	default "ChangeMe1234"
	help
	  Prototype default only. Override in a local/pristine overlay for real use.
	  Leave empty to start an open SoftAP.

config ESP_NMEA_BRIDGE_STA_SSID
	string "STA target AP SSID"
	default ""

config ESP_NMEA_BRIDGE_STA_PSK
	string "STA target AP password"
	default ""

config ESP_NMEA_BRIDGE_STA_ROTATE_MAC
	bool "Rotate STA MAC address on boot"
	default y
	depends on ESP_NMEA_BRIDGE_STA_ENABLE
	help
	  Use a random locally administered STA MAC address on each boot. This
	  avoids stale station state on APs that keep the previous association
	  after the ESP resets without sending a deauthentication frame.

config ESP_NMEA_BRIDGE_TCP_NMEA_PORT
	int "TCP NMEA port"
	default 10110

config ESP_NMEA_BRIDGE_TCP_NMEA_SERVER_MAX_PEERS
	int "Maximum TCP NMEA server peers"
	default 3
	range 1 8

config ESP_NMEA_BRIDGE_NMEA_SINKS_MAX
	int "Maximum NMEA bridge sinks"
	default 4
	range 1 9
	help
	  Maximum concurrent sinks registered with the in-process NMEA bridge.
	  TCP NMEA server sessions and the outbound TCP NMEA client each consume
	  one sink while connected. Keep this at least TCP_NMEA_SERVER_MAX_PEERS
	  plus one when the TCP NMEA client is enabled.

config ESP_NMEA_BRIDGE_NMEA_FRAME_MAX_LEN
	int "Maximum NMEA frame length"
	default 128
	range 32 512

config ESP_NMEA_BRIDGE_INGEST_QUEUE_DEPTH
	int "NMEA ingest queue depth"
	default 32
	range 2 256

config ESP_NMEA_BRIDGE_SINK_QUEUE_DEPTH
	int "Per-sink NMEA queue depth"
	default 16
	range 2 128

config ESP_NMEA_BRIDGE_AP_IP_ADDRESS
	string "SoftAP IPv4 address"
	default "192.168.4.1"

config ESP_NMEA_BRIDGE_AP_NETMASK
	string "SoftAP IPv4 netmask"
	default "255.255.255.0"

endmenu

source "Kconfig.zephyr"
